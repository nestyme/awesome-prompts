# Copy to tools/.env (gitignored) and fill in. _common.py auto-loads tools/.env
# for every tool — no need to `source` it. Real environment vars always win over
# this file, so CI/prod secrets are never overridden.

# --- Gemini (gen_image.py) --------------------------------------------------
# Any ONE of these is accepted. Value is an AI Studio key (starts with "AIza...").
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# --- fal.ai / Kling (gen_video.py) ------------------------------------------
# Any ONE of these is accepted.
FAL_KEY=
# FAL_AI_API_KEY=

# --- Postiz scheduling (schedule_post.py) -----------------------------------
POSTIZ_API_KEY=
# POSTIZ_BASE_URL=https://api.postiz.com
